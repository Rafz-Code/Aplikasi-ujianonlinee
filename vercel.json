{
  "version": 2,
  "functions": {
    "server.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/((?!assets/|favicon.ico|manifest.json).*)",
      "destination": "/server.ts"
    }
  ]
}
